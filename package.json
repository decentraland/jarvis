{
  "name": "@dcl/jarvis",
  "version": "0.0.0-development",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decentraland/jarvis.git"
  },
  "description": "Decentraland services and UI manifests",
  "type": "module",
  "files": [
    "manifests"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "tsx --env-file=.env src/generate.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "license": "Apache-2.0",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.55.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.1",
    "semantic-release": "^25.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2"
  }
}
